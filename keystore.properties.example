# Copy this file to keystore.properties and fill in real values.
# keystore.properties is ignored by git and should stay local.

# Absolute or project-relative path to your release keystore file.
storeFile=/absolute/path/to/ivi-release.jks

# Password for the keystore.
storePassword=change_me

# Alias of the signing key inside the keystore.
keyAlias=ivi

# Password for the signing key.
# If omitted in keystore.properties, Gradle will reuse storePassword.
keyPassword=change_me
